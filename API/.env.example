# Port the API listens on (optional, defaults to 3000)
PORT=3000

# MongoDB connection string (OPTIONAL).
# Leave this blank/unset to run with a self-contained in-memory MongoDB that is
# automatically seeded on startup — no database or credentials required.
# Set it only if you want to persist data to your own MongoDB (e.g. Atlas):
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
